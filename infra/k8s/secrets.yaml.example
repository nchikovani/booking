# Copy this file to secrets.yaml and fill in the values.
# DO NOT commit secrets.yaml to git.
# Create secret: kubectl apply -f secrets.yaml
apiVersion: v1
kind: Secret
metadata:
  name: booking-secrets
  namespace: booking
type: Opaque
stringData:
  POSTGRES_PASSWORD: "booking"
  DATABASE_URL: "postgresql://booking:booking@postgres:5432/booking"
  REDIS_URL: "redis://redis:6379"
  MINIO_ACCESS_KEY: "minioadmin"
  MINIO_SECRET_KEY: "minioadmin"
  TELEGRAM_BOT_TOKEN: ""

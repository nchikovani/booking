generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProviderType {
  EMAIL_PASSWORD
  // GOOGLE, MAGIC_LINK — в будущем
}

enum BusinessRole {
  OWNER
  // ADMIN — в будущем
}

model AdminUser {
  id             String    @id @default(uuid())
  email          String?   @unique
  firstName      String?
  lastName       String?
  emailVerifiedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  authProviders       AuthProvider[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  businessMembers     BusinessMember[]
}

model Business {
  id          String   @id @default(uuid())
  name        String?
  description String?  @db.Text
  logoPath    String?  @map("logo_path")
  imagePath   String?  @map("image_path")
  phone       String?
  email       String?
  website     String?
  telegram    String?
  vk          String?
  youtube     String?
  address     String?  @db.Text
  latitude    Float?
  longitude   Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  businessMembers   BusinessMember[]
  serviceCategories ServiceCategory[]
  services          Service[]
  employees         Employee[]

  @@map("businesses")
}

model BusinessMember {
  id          String       @id @default(uuid())
  adminUserId String       @map("admin_user_id")
  businessId  String       @map("business_id")
  role        BusinessRole @default(OWNER)
  createdAt   DateTime     @default(now())

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  business  Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([adminUserId, businessId])
  @@index([businessId])
  @@map("business_members")
}

model ServiceCategory {
  id         String   @id @default(uuid())
  businessId String   @map("business_id")
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  services Service[]

  @@unique([businessId, name])
  @@index([businessId])
  @@map("service_categories")
}

model Service {
  id                 String   @id @default(uuid())
  businessId         String   @map("business_id")
  categoryId        String?  @map("category_id")
  name               String
  description        String?  @db.Text
  price              Decimal  @db.Decimal(10, 2)
  durationMinutes    Int      @map("duration_minutes")
  breakAfterMinutes  Int?     @map("break_after_minutes") @default(0)
  position           Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  business          Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category          ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  employeeServices  EmployeeService[]

  @@index([businessId])
  @@index([businessId, categoryId])
  @@index([businessId, position])
  @@map("services")
}

model Employee {
  id             String   @id @default(uuid())
  businessId     String   @map("business_id")
  name           String
  specialization String?  @map("specialization")
  imagePath      String?  @map("image_path")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  business         Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  employeeServices EmployeeService[]

  @@index([businessId])
  @@map("employees")
}

model EmployeeService {
  id         String   @id @default(uuid())
  employeeId String   @map("employee_id")
  serviceId  String   @map("service_id")
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([employeeId, serviceId])
  @@index([employeeId])
  @@index([serviceId])
  @@map("employee_services")
}

model AuthProvider {
  id          String          @id @default(uuid())
  adminUserId String          @map("admin_user_id")
  type        AuthProviderType
  providerId  String?         @map("provider_id")
  createdAt   DateTime        @default(now())

  adminUser   AdminUser       @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  credential  UserCredential?

  @@unique([adminUserId, type])
  @@map("auth_providers")
}

model UserCredential {
  id             String   @id @default(uuid())
  authProviderId String   @unique @map("auth_provider_id")
  passwordHash   String   @map("password_hash")
  updatedAt      DateTime @updatedAt

  authProvider AuthProvider @relation(fields: [authProviderId], references: [id], onDelete: Cascade)

  @@map("user_credentials")
}

model RefreshToken {
  id          String    @id @default(uuid())
  adminUserId String    @map("admin_user_id")
  tokenHash   String    @unique @map("token_hash")
  deviceInfo  String?   @map("device_info")
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  replacedBy  String?   @map("replaced_by")
  createdAt   DateTime  @default(now())

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model LoginAttempt {
  id        String   @id @default(uuid())
  email     String
  ipAddress String?  @map("ip_address")
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
  @@map("login_attempts")
}

model PasswordResetToken {
  id          String    @id @default(uuid())
  adminUserId String    @map("admin_user_id")
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now())

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

{
  "name": "@repo/prisma",
  "version": "0.0.0",
  "private": true,
  "main": "./generated/index.js",
  "types": "./generated/index.d.ts",
  "exports": {
    ".": {
      "types": "./generated/index.d.ts",
      "default": "./generated/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate --schema=./schema.prisma",
    "postinstall": "prisma generate --schema=./schema.prisma",
    "generate": "prisma generate --schema=./schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=./schema.prisma",
    "db:push": "prisma db push --schema=./schema.prisma",
    "db:studio": "prisma studio --schema=./schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.16.2"
  },
  "devDependencies": {
    "prisma": "^6.16.2"
  }
}